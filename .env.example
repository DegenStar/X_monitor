# === Twitter / X API ===
# 在 https://developer.twitter.com/ 获取的 Bearer Token
BEARER_TOKEN=

# === Telegram ===
# 通过 @BotFather 创建的机器人 Token
TELEGRAM_BOT_TOKEN=
# 接收通知的聊天 ID（个人 / 群组 / 频道）
TELEGRAM_CHAT_ID=

# === 监听设置 ===
# 要监听的用户名（无需 @）。多个用逗号分隔
USERNAMES_TO_TRACK=RobinhoodCrypto,vladtenev,BaijuBhatt,theunipcs,traderpow,JohannKerbrat,fern

# 轮询间隔（秒）。注意免费额度的限流（建议 60 以上）
POLL_INTERVAL=180

# 每个用户获取之后的等待间隔（秒），用于缓解限流
REQUEST_DELAY=2

# 是否将新推文在 Telegram 中自动置顶（true/false）
PIN_MESSAGE=false

# 翻译目标语言。留空则关闭翻译
TRANSLATE_TO=zh-CN

# 状态文件（保存最后处理的推文 ID）
STATE_FILE=latest_tweet_ids.json


# ============================================================
# === RSS 方案（rss_monitor.py，免费替代 X API）===
# ============================================================
# 说明：X 无官方 RSS，需借助第三方源（Nitter / RSSHub / rss.app 等）。
# 以下两种方式二选一，或同时使用：

# 方式 A：按模板为每个用户自动拼接 feed URL（复用上面的 USERNAMES_TO_TRACK）。
# 必须包含 {username} 占位符。示例：
RSS_BASE_URL=https://xcancel.com/{username}/rss,https://nitter.net/{username}/rss,https://nitter.privacyredirect.com/{username}/rss

# 方式 B：直接给出完整 feed URL，逗号分隔。可用 `名称|URL` 指定显示名。
# 示例：RSS_FEEDS=马斯克|https://nitter.net/elonmusk/rss,https://example.com/feed.xml
# RSS_FEEDS=

# RSS 版的状态文件（与 API 版分开，避免互相覆盖）
# STATE_FILE=latest_rss_ids.json
